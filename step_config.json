        "min_std_conservative":        {"source": "special", "special": "step7d_min_std_conservative"},
        "min_std_balanced":            {"source": "special", "special": "step7d_min_std_balanced"},
        "min_std_aggressive":          {"source": "special", "special": "step7d_min_std_aggressive"},
        "penalty_scale_conservative":  {"source": "special", "special": "step7d_penalty_scale_conservative"},
        "penalty_scale_balanced":      {"source": "special", "special": "step7d_penalty_scale_balanced"},
        "penalty_scale_aggressive":    {"source": "special", "special": "step7d_penalty_scale_aggressive"},
        "spatial_score_mean":          {"source": "special", "special": "step7d_spatial_score_mean"},

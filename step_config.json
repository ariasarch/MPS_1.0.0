        "component_source": {"source": "results", "default": "merged"},
        "n_initial":        {"source": "special", "special": "step6e_n_initial"},
        "n_filtered":       {"source": "special", "special": "step6e_n_filtered"},
        "variables_saved":  {"source": "special", "special": "step6e_variables_saved"},
        "saving_timestamp": {"source": "special", "special": "step6e_saving_timestamp"}
      }
    },
    "step7a_dilate": {
      "results_key": "step7a",

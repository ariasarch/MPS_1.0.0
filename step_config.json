        "active_pixels_before": {"source": "results", "default": 0},
        "active_pixels_after":  {"source": "results", "default": 0},
        "variables_saved":      {"source": "special", "special": "step7a_variables_saved"},
        "saving_timestamp":     {"source": "special", "special": "step7a_saving_timestamp"}
      }
    },
    "step7b_cluster": {
